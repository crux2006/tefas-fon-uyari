# Genel
BASE_DIR=.
DATA_DIR=./data
REPORTS_DIR=./reports
DB_PATH=./data/fund_alerts.sqlite

# Tarama
FUND_TYPE=yatirim
PERIODS=gunluk,haftalik,aylik
KATILIM_ONLY=false
EXCLUDED_CATEGORIES=Para Piyasası Fonları
LOOKBACK_DAYS=60
MIN_HISTORY_POINTS=10
TOP_N_ALERTS=10

# Sinyal eşikleri
MIN_SIGNAL_SCORE=0.90
MIN_INTEREST_SCORE=0.60
MIN_ACCELERATION=0.15

# Grafik
CHART_COMPARE_RANGE=1Y
CHART_COMPARE_RANGES=1M,3M,6M,9M,1Y
CHART_COMPARE_METRIC=fiyat

# Telegram
SEND_TELEGRAM=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=   # örnek: 123456789
